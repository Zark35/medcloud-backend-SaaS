# Copia a .env antes de Docker Compose:
#   cp .env.docker.example .env
# Windows: Copy-Item .env.docker.example .env

# --- Django (producción local con Nginx + Gunicorn) ---
DJANGO_SECRET_KEY=change-me-to-a-long-random-secret-key-min-50-chars
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=localhost 127.0.0.1 nginx
DJANGO_ALLOW_ALL_ORIGINS=True
# En producción real, desactiva ALLOW_ALL y define orígenes:
# DJANGO_ALLOW_ALL_ORIGINS=False
# CORS_ALLOWED_ORIGINS=https://tu-frontend.com

BEHIND_PROXY=True
USE_X_FORWARDED_HOST=True
# CSRF_TRUSTED_ORIGINS=https://tu-dominio.onrender.com

# --- Base de datos (Docker Compose) ---
USE_POSTGRESQL=True
POSTGRES_DB=medcloud
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=db
POSTGRES_PORT=5432

# --- Gunicorn ---
GUNICORN_WORKERS=2
GUNICORN_TIMEOUT=120

# --- Bootstrap superusuario (opcional, útil en Render free sin shell) ---
# Si CREATE_SUPERUSER=True, el entrypoint crea/ajusta este usuario en cada arranque (idempotente).
CREATE_SUPERUSER=False
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@example.com
DJANGO_SUPERUSER_PASSWORD=change-me-now

# --- Puertos en tu máquina (host) ---
# Nginx escucha dentro del contenedor en :80 y se publica aquí:
WEB_PORT=8000
POSTGRES_PUBLISH_PORT=5432
